<!DOCTYPE html>
<html>
<head>
    <title>My Personal Website</title>

    <!-- 🔹 External CSS -->
    <link rel="stylesheet" href="style.css">

    <!-- 🔹 Internal CSS -->
    <style>
        body {
            font-family: Arial;
            background-color: #f4f4f4;
        }

        h1 {
            color: darkblue;
            text-align: center;
        }

        section {
            background-color: white;
            padding: 15px;
            margin: 20px;
            border: 1px solid #ccc;
        }

        nav a {
            margin-right: 15px;
            text-decoration: none;
            color: darkgreen;
            font-weight: bold;
        }
    </style>
</head>

<body>

<!-- 🔹 Inline CSS -->
<h1 style="color: darkred;">My Personal Website</h1>

<nav style="text-align:center;">
    <a href="#home">Home</a>
    <a href="#about">About</a>
    <a href="#education">Education</a>
    <a href="#contact">Contact</a>
</nav>

<hr>

<section id="home">
    <h2>Home</h2>
    <p style="color: gray;">Welcome to my personal website.</p>
</section>

<section id="about">
    <h2>About Me</h2>
    <p>My name is Navya Royal.</p>
    <p>I am learning HTML and CSS.</p>
</section>

<section id="education">
    <h2>Education</h2>
    <ul>
        <li>School: ABC School</li>
        <li>College: XYZ College</li>
        <li>Course: Computer Science</li>
    </ul>
</section>

<section id="contact">
    <h2>Contact</h2>
    <p>Email: navya@email.com</p>
    <p>Phone: 1234567890</p>
</section>

<footer>
    <p>&copy; 2026 My Website</p>
</footer>

</body>
</html>
